# Server bind settings
# 0.0.0.0 allows access from VPS public IP/reverse proxy.
HOST=0.0.0.0
PORT=3000

# Optional: absolute project root override (used for resolving ./data)
# Example: /home/reaby/infoscreen4
#INFOSCREEN_ROOT=

# Optional: absolute data directory override (takes precedence over INFOSCREEN_ROOT)
# Example: /home/reaby/infoscreen4/data
#INFOSCREEN_DATA_DIR=
